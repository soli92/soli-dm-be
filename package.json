{
  "name": "soli-dm-be",
  "version": "1.0.0",
  "description": "Soli Dungeon Master - Backend API for D&D campaign management",
  "main": "dist/server.js",
  "scripts": {
    "dev": "node --loader tsx src/server.ts",
    "build": "tsc",
    "postbuild": "echo 'Build completed successfully'",
    "start": "node scripts/start.cjs",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke:cors": "node scripts/cors-smoke.mjs"
  },
  "keywords": [
    "dnd",
    "dungeons-and-dragons",
    "dungeon-master",
    "campaign-management",
    "api",
    "express",
    "typescript"
  ],
  "author": "soli92",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.40.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.5",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@types/supertest": "^6.0.2",
    "supertest": "^7.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^3.0.5"
  }
}
