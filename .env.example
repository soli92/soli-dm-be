# 🎲 SOLI-DM BACKEND — Environment Variables
# Copia questo file a .env e riempilo con i tuoi valori

# ========== SERVER ==========
PORT=5000
NODE_ENV=production
# Valori validi: development, staging, production

# ========== SUPABASE ==========
# Ottieni questi valori da https://supabase.com/dashboard → Progetto → Settings
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-key-here
# ⚠️ SERVICE_KEY è privato — USA SOLO NEL BACKEND!

# ========== CORS ==========
# URL del frontend (per CORS). Su produzione: URL di Vercel
CORS_ORIGIN=https://soli-dm-5e8u7w4b0-soli92s-projects.vercel.app
# In locale: http://localhost:3000

# ========== AUTENTICAZIONE ==========
# JWT Secret per firmare i token (genera un valore casuale lungo)
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-long
# Genera con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# Google OAuth (Opzionale — configurato in Supabase)
# Se usi Supabase Auth, questi non servono nel backend
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ========== LOGGING ==========
LOG_LEVEL=info
# Valori: trace, debug, info, warn, error, fatal

# ========== RATE LIMITING ==========
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
# 900000 ms = 15 minuti; max 100 requests per finestra

# ========== SENTRY (Opzionale — Error Tracking) ==========
SENTRY_DSN=
# Lascia vuoto se non usi Sentry

# ========== DATABASE (Opzionale — se usi connessione diretta) ==========
DATABASE_URL=
# Formato: postgresql://user:password@host:port/database
# Supabase fornisce questo nel dashboard → Database → Connection Pooling
