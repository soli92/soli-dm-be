# 🎲 SOLI-DM BACKEND — Environment Variables
# Copia questo file a .env e riempilo con i tuoi valori

# ========== SERVER ==========
PORT=5000
NODE_ENV=production
# Valori validi: development, staging, production

# ========== SUPABASE ==========
# Ottieni questi valori da https://supabase.com/dashboard → Progetto → Settings
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-key-here
# ⚠️ SERVICE_KEY è privato — USA SOLO NEL BACKEND!

# Wiki SRD sync (`npm run sync:wiki-srd`) — opzionale, default API 2014
# SOLI_DND5E_API_BASE=https://www.dnd5eapi.co/api/2014

# ========== CORS ==========
# Una o più origini separate da virgola (spazi trimmati; virgolette attorno al valore sono tollerate)
# Su Render: inserisci l’URL esatto del frontend, senza path (es. https://soli-dm-fe.vercel.app)
CORS_ORIGIN=http://localhost:3000
# Produzione es.: https://soli-dm-fe.vercel.app
# Più domini: https://soli-dm-fe.vercel.app,https://altro.example.com

# Preview Vercel (URL tipo *-soli92s-projects.vercel.app): consenti se true
# CORS_ALLOW_VERCEL_PREVIEW=true
# Opzionale: sottostringa nell’hostname (default soli-dm)
# CORS_VERCEL_PREVIEW_SUBSTRING=soli-dm

# ========== API KEY (opzionale) ==========
# Se valorizzata, tutte le route sotto /api richiedono header:
#   x-soli-dm-api-key: <valore>   oppure   Authorization: Bearer <valore>
# /health resta sempre pubblico. Lascia vuota in dev locale senza header.
# SOLI_DM_API_KEY=

# ========== AUTENTICAZIONE ==========
# JWT Secret per firmare i token (genera un valore casuale lungo)
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-long
# Genera con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# Google OAuth (Opzionale — configurato in Supabase)
# Se usi Supabase Auth, questi non servono nel backend
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ========== LOGGING ==========
LOG_LEVEL=info
# Valori: trace, debug, info, warn, error, fatal

# ========== RATE LIMITING ==========
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
# 900000 ms = 15 minuti; max 100 requests per finestra

# ========== SENTRY (Opzionale — Error Tracking) ==========
SENTRY_DSN=
# Lascia vuoto se non usi Sentry

# ========== DATABASE (Opzionale — se usi connessione diretta) ==========
DATABASE_URL=
# Formato: postgresql://user:password@host:port/database
# Supabase fornisce questo nel dashboard → Database → Connection Pooling
